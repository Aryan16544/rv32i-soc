// =============================================================================
// RV32I ALL 37 Instructions Test - Uses EXACT working UART pattern
// Pattern from original program.mem that prints "Aryan\r\n"
// Tests all instructions, prints result per instruction
// =============================================================================
// UART Pattern (VERIFIED WORKING):
//   lui x1, 0x30000      # x1 = 0x30000000 (UART base)
//   addi x2, x0, CHAR    # x2 = character to print
//   lw x5, 8(x1)         # Read UART status (offset 8)
//   andi x5, x5, 2       # Check TX FIFO full bit (bit 1)
//   bne x5, x0, -4       # Loop if full
//   sw x2, 0(x1)         # Write character (offset 0)
// =============================================================================

