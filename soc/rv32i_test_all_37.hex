// =============================================================================
// RV32I Full Instruction Test Suite - Pre-assembled HEX
// Tests all 37 RV32I base instructions with UART output
// Format: Each instruction prints "[NAME]: PASS" or "[NAME]: FAIL" to UART
// =============================================================================
// Memory Map Used:
//   UART_BASE   = 0x30000000
//   UART_TX     = 0x30000000 (offset 0x00)
//   UART_STATUS = 0x30000008 (offset 0x08) - bit 1 = TX full
//   DATA_MEM    = 0x10000000 (for load/store tests)
// =============================================================================
// Expected UART Output (at 9600 baud):
//   RV32I TEST
//   LUI: PASS
//   AUIPC: PASS
//   JAL: PASS
//   JALR: PASS
//   BEQ: PASS
//   BNE: PASS
//   BLT: PASS
//   BGE: PASS
//   BLTU: PASS
//   BGEU: PASS
//   LW: PASS
//   LH: PASS
//   LHU: PASS
//   LB: PASS
//   LBU: PASS
//   SB: PASS
//   SH: PASS
//   SW: PASS
//   ADDI: PASS
//   SLTI: PASS
//   SLTIU: PASS
//   XORI: PASS
//   ORI: PASS
//   ANDI: PASS
//   SLLI: PASS
//   SRLI: PASS
//   SRAI: PASS
//   ADD: PASS
//   SUB: PASS
//   SLL: PASS
//   SLT: PASS
//   SLTU: PASS
//   XOR: PASS
//   SRL: PASS
//   SRA: PASS
//   OR: PASS
//   AND: PASS
//   DONE!
// =============================================================================

// ADDR 0x000: lui x1, 0x30000       # x1 = UART_BASE
300000b7
