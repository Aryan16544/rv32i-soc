// =============================================================================
// BLOCK 1: ALL IMMEDIATE INSTRUCTIONS (9)
// ADDI, SLTI, SLTIU, XORI, ORI, ANDI, SLLI, SRLI, SRAI
// =============================================================================

// Print 'I' for Immediate block
04900113
0080a283
0022f293
fe029ce3
0020a023

// ADDI: x10 = 100
06400513
// SLTI: x11 = (x10 < 200) = 1
0c852593
// SLTIU: x12 = (x10 < 200 unsigned) = 1
0c853613
// XORI: x13 = x10 ^ 0xFF = 100 ^ 255 = 155
0ff54693
// ORI: x14 = x10 | 0x0F = 100 | 15 = 111
00f56713
// ANDI: x15 = x10 & 0x0F = 100 & 15 = 4
00f57793
// SLLI: x16 = x10 << 2 = 400
00251813
// SRLI: x17 = x10 >> 2 = 25
00255893
// SRAI: x18 = (-100) >> 2 = -25
f9c00913
40295913

// =============================================================================
// BLOCK 2: ALL R-TYPE INSTRUCTIONS (10)
// ADD, SUB, SLL, SLT, SLTU, XOR, SRL, SRA, OR, AND
// =============================================================================

// Print 'R' for R-type block
05200113
0080a283
0022f293
fe029ce3
0020a023

// Setup: x20 = 50, x21 = 30
03200a13
01e00a93
// ADD: x22 = x20 + x21 = 80
015a0b33
// SUB: x23 = x20 - x21 = 20
415a0bb3
// SLL: x24 = x20 << (x21 & 0x1F) = 50 << 30 (big number)
015a1c33
// SLT: x25 = (x20 < x21) = 0 (50 >= 30)
015a2cb3
// SLTU: x26 = (x20 < x21 unsigned) = 0
015a3d33
// XOR: x27 = x20 ^ x21
015a4db3
// SRL: x28 = x20 >> x21 (shift by 30 bits)
015a5e33
// SRA: x29 = x20 >> x21 (arithmetic)
415a5eb3
// OR: x30 = x20 | x21
015a6f33
// AND: x31 = x20 & x21
015a7fb3

